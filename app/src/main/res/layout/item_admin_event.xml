<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#33FFFFFF"
    android:backgroundTint="#EED2D2">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvAdminEventTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Event Title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#6B2B2B"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAdminEventDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Date: 2026-03-10"
            android:textColor="#7A3A3A"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAdminEventLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Location: Downtown"
            android:textColor="#7A3A3A"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAdminEventCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Category: Comedy"
            android:textColor="#7A3A3A"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventLocation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAdminEventCapacity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Capacity: 100"
            android:textColor="#7A3A3A"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventCategory"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAdminEventSummary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Seats: 100/100 (0 Reserved)"
            android:textColor="#6B2B2B"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventCapacity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAdminEventStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#B91C1C"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventSummary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvAdminEventStatus"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminEdit"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/btn_pill"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="Edit"
                android:textAllCaps="false"
                android:textColor="#6B2B2B"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminCancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/btn_pill"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#6B2B2B"
                app:cornerRadius="20dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdminUncancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/btn_pill"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="Uncancel"
                android:textAllCaps="false"
                android:textColor="#6B2B2B"
                app:cornerRadius="20dp"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>