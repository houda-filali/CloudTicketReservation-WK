<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pink_gradient">

    <LinearLayout
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/card_soft"
        android:padding="26dp"
        android:orientation="vertical"
        app:layout_constraintWidth_max="420dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Login"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="#6B2B2B"
            android:gravity="center"
            android:layout_marginBottom="18dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email or Phone Number"
            app:boxBackgroundMode="none"
            app:hintTextColor="#7A3A3A"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_dialog_email">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="#4B1E1E"
                android:textColorHint="#7A3A3A" />
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#9B5B5B"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:alpha="0.55" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            app:boxBackgroundMode="none"
            app:hintTextColor="#7A3A3A"
            app:endIconMode="password_toggle"
            app:endIconTint="#7A3A3A">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="#4B1E1E"
                android:textColorHint="#7A3A3A" />
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#9B5B5B"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:alpha="0.55" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirm password"
            android:visibility="gone"
            app:boxBackgroundMode="none"
            app:hintTextColor="#7A3A3A"
            app:endIconMode="password_toggle"
            app:endIconTint="#7A3A3A">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="#4B1E1E"
                android:textColorHint="#7A3A3A" />
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:id="@+id/divConfirm"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#9B5B5B"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp"
            android:alpha="0.55"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#B91C1C"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="230dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:background="@drawable/btn_pill"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Login"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#6B2B2B"
            android:elevation="0dp"
            app:cornerRadius="26dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp"
            android:weightSum="2">

            <TextView
                android:id="@+id/tvCreateAccount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Create an account"
                android:textSize="14sp"
                android:textColor="#7A3A3A" />

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Forgot password"
                android:textSize="14sp"
                android:textColor="#7A3A3A"
                android:gravity="end" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>