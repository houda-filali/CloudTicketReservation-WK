<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pink_gradient"
    android:fillViewport="true"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/cardDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_soft"
            android:padding="18dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event Title"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#6B2B2B"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvDetailsDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#7A3A3A" />

            <TextView
                android:id="@+id/tvDetailsLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textColor="#7A3A3A"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDetailsCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#7A3A3A"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDetailsDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#4B1E1E"
                android:layout_marginTop="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToEvents"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_pill"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="Back to events"
                android:textAllCaps="false"
                android:textColor="#6B2B2B"
                app:cornerRadius="24dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardReserve"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_soft"
            android:padding="18dp"
            android:orientation="vertical"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reserve"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#6B2B2B"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTickets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Number of tickets"
                app:boxBackgroundMode="none"
                app:hintTextColor="#7A3A3A">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTickets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="#4B1E1E"
                    android:textColorHint="#7A3A3A" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#9B5B5B"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:alpha="0.55" />

            <TextView
                android:id="@+id/tvReserveError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B91C1C"
                android:visibility="gone"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReserve"
                android:layout_width="230dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:background="@drawable/btn_pill"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:text="Confirm reservation"
                android:textAllCaps="false"
                android:textColor="#6B2B2B"
                app:cornerRadius="26dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>