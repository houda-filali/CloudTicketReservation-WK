<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pink_gradient"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/card_soft"
        android:padding="18dp"
        android:orientation="vertical"
        app:layout_constraintWidth_max="520dp"
        app:layout_constrainedWidth="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvAdminTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Admin Dashboard"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textColor="#6B2B2B"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabAddEvent"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/btn_pill"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="Add Event"
            android:textAllCaps="false"
            android:textColor="#6B2B2B"
            app:cornerRadius="26dp" />

        <TextView
            android:id="@+id/tvAdminEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No events"
            android:textColor="#7A3A3A"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAdminEvents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="6dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>